# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Frontend build outputs
dist/
build/

# Python / Whisper virtual environment
.venv-whisper/
__pycache__/
*.pyc

# Local media assets
assets/

# Local form uploads / temporary browser uploads
uploads/
tarinakioski-lomake/uploads/

# Input source videos are usually too large for GitHub
input/**/*.mov
input/**/*.mp4
input/**/*.avi
input/**/*.mkv
input/**/*.webm

# Generated subtitles and temporary transcription outputs
subtitles/
*.srt
*.vtt
*.ass
*.tsv
*.subtitles.json

# Keep ordinary .txt files visible for documentation/readmes.
# If transcript .txt files are generated later, ignore them with a narrower path.

# Nexrender generated / temporary subtitle jobs
job-*-subtitles.json

# After Effects autosaves and cache-like files
Adobe After Effects Auto-Save/
*.aepx
*.aet
*.tmp

# OS / editor
.DS_Store
Thumbs.db
.vscode/